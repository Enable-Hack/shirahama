      "Bash(*echo*>*/etc/*)",
      "Bash(*echo*>>*/etc/*)",
      "Bash(*echo*>*/var/*)",
      "Bash(*echo*>>*/var/*)",
      "Bash(*sed*-i*/etc/*)",
      "Bash(*sed*-i*/var/*)",
      "Bash(*tee*/etc/*)",
      "Bash(*tee*/var/*)",
      "Bash(*systemctl*start*)",
      "Bash(*systemctl*stop*)",
      "Bash(*systemctl*restart*)",
      "Bash(*systemctl*reload*)",
      "Bash(*systemctl*disable*)",
      "Bash(*systemctl*enable*)",
      "Bash(*systemctl*mask*)",
      "Bash(*service*start*)",
      "Bash(*service*stop*)",
      "Bash(*service*restart*)",
      "Bash(*dnf*install*)",
      "Bash(*dnf*remove*)",
      "Bash(*dnf*update*)",
      "Bash(*dnf*upgrade*)",
      "Bash(*yum*install*)",
      "Bash(*yum*remove*)",
