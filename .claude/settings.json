{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment_purpose": "デモ環境 build phase 専用 settings。OCI 上に whiskey lab を再構築するために dnf install / systemctl / mysql DDL / Edit(/etc) 等を一時的に許可する。本番運用時は必ず settings.production.json をコピーして上書き戻すこと。",
  "_comment_mode": "BUILD MODE — DO NOT USE DURING TOURNAMENT. Restore production settings before 5/5 runtime.",

  "model": "claude-opus-4-7",

  "permissions": {
    "_comment_deny": "build phase でも絶対に避けるべき破壊的操作のみ残す。誤って母艦やルートを破壊しないため。",
    "deny": [
      "Bash(*rm*-rf*/*)",
      "Bash(*rm*-fr*/*)",
      "Bash(*shutdown*)",
      "Bash(*reboot*)",
      "Bash(*halt*)",
      "Bash(*poweroff*)",
      "Bash(*init*0*)",
      "Bash(*init*6*)",
      "Bash(*history*-c*)",
      "Bash(*shred*)",
      "Bash(*: > /var/log/*)",
      "Bash(*rm*/var/log/*)",
      "Bash(*dd*if=*of=/dev/sd*)",
      "Bash(*mkfs*)",
      "Bash(*fdisk*/dev/*)"
    ],

    "_comment_ask": "build phase でも人間確認させたい操作。",
    "ask": [
      "Bash(*iptables*-j DROP*)",
      "Bash(*iptables*-F*)",
      "Bash(*kill*-9*)",
      "Bash(*killall*)",
      "Bash(*userdel*)",
      "Bash(*rm*-rf*)"
    ],

    "_comment_allow": "build phase で必要なインストール / 設定 / サービス操作。本番では deny に戻る。",
    "allow": [
      "Bash(ssh victor *)",
      "Bash(ssh bravo *)",
      "Bash(ssh attack-vm *)",
      "Bash(ssh manage@*)",
      "Bash(ssh root@*)",
      "Bash(scp *)",
      "Bash(rsync *)",
      "Bash(dig *)",
      "Bash(host *)",
      "Bash(nslookup *)",
      "Bash(ping -c * *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(grep *)",
      "Bash(awk *)",
      "Bash(sed *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(less *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(df *)",
      "Bash(du *)",
      "Bash(find *)",
      "Bash(uptime)",
      "Bash(who)",
      "Bash(w)",
      "Bash(last *)",
      "Bash(ss *)",
      "Bash(sockstat *)",
      "Bash(netstat *)",
      "Bash(ps *)",
      "Bash(pgrep *)",
      "Bash(rpm -q*)",
      "Bash(rpm -i*)",
      "Bash(rpm -e*)",
      "Bash(dnf *)",
      "Bash(yum *)",
      "Bash(systemctl *)",
      "Bash(service *)",
      "Bash(journalctl *)",
      "Bash(php *)",
      "Bash(mysql *)",
      "Bash(mysqldump *)",
      "Bash(mariadb *)",
      "Bash(named *)",
      "Bash(rndc *)",
      "Bash(snmpwalk *)",
      "Bash(doveconf *)",
      "Bash(postconf *)",
      "Bash(mailq)",
      "Bash(uname *)",
      "Bash(hostname *)",
      "Bash(id *)",
      "Bash(groups *)",
      "Bash(getenforce)",
      "Bash(sestatus)",
      "Bash(setenforce *)",
      "Bash(chmod *)",
      "Bash(chown *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(ln *)",
      "Bash(tar *)",
      "Bash(unzip *)",
      "Bash(gzip *)",
      "Bash(gunzip *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(bash *)",
      "Bash(sh *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(true)",
      "Bash(false)",
      "Bash(test *)",
      "Bash([ * ])",
      "Edit(/Users/ryu/Desktop/shirahama/**)",
      "Edit(/etc/**)",
      "Edit(/var/**)",
      "Write(/Users/ryu/Desktop/shirahama/**)",
      "Write(/tmp/**)",
      "Write(/etc/**)",
      "Write(/var/**)",
      "Read(//Users/ryu/Desktop/shirahama/**)",
      "Read(/**)"
    ]
  },

  "_comment_env": "build mode を明示するための環境変数。SSH_* は incident.md / check-*.md が ssh 接続先を切替えるのに使う。SHIRAHAMA_PY は anthropic 入りの pyenv 3.12.6 を絶対パスで指定（Homebrew python3.14 には anthropic 未導入のため）。",
  "env": {
    "SHIRAHAMA_MODE": "build",
    "SSH_VICTOR": "victor",
    "SSH_BRAVO": "bravo",
    "SHIRAHAMA_DIR": "/Users/ryu/Desktop/shirahama",
    "SHIRAHAMA_PY": "/opt/homebrew/var/pyenv/versions/3.12.6/bin/python3"
  }
}
